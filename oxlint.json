{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "rules": {
    "no-unused-vars": "error",
    "no-console": "error",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error",
    "no-shadow": "error",
    "typescript/no-explicit-any": "error"
  },
  "ignorePatterns": ["src/mbt.d.ts"]
}
